# ── Bybit API ──────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true          # true = testnet, false = mainnet

# ── Trading Config ─────────────────────────────────
SYMBOL=BTCUSDT
TRADING_INTERVAL=60         # seconds between each trading cycle

# ── Database ───────────────────────────────────────
POSTGRES_PASSWORD=tradingpass
DATABASE_URL=postgresql://trader:tradingpass@postgres:5432/trading

# ── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── App ────────────────────────────────────────────
SECRET_KEY=change_me_to_random_string
